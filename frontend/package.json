{
  "name": "online-clipboard",
  "version": "0.0.40",
  "private": true,
  "scripts": {
    "gen-metadata": "cd .. && cd server && poetry run python wsgi.py --export-metadata ../frontend/src/metadata.json && cd .. && cd frontend",
    "vercel-gen-metadata": "cd .. && cd server && python3 -m poetry run python wsgi.py --export-metadata ../frontend/src/metadata.json && cd .. && cd frontend",
    "dev": "yarn run gen-metadata && vite",
    "build": "yarn run gen-metadata && vite build --emptyOutDir",
    "vercel-build": "yarn run vercel-gen-metadata && vite build --emptyOutDir",
    "preview": "vite preview",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@dmsnell/diff-match-patch": "^1.1.0",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@types/crypto-js": "^4.2.1",
    "axios": "^1.16.1",
    "buffer": "^6.0.3",
    "core-js": "^3.49.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "mime": "^4.1.0",
    "nanoid": "^5.1.11",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "socket.io-client": "^4.8.3",
    "sweetalert2": "^11.26.24",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "v-github-icon": "^3.3.0",
    "vue": "^3.5.34",
    "vue-i18n": "11.4.4",
    "vue-router": "^5.0.7",
    "vuetify": "^4.0.7"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@mdi/js": "^7.4.47",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "typescript-eslint": "^8.59.4",
    "unplugin-fonts": "^2.0.0",
    "vite": "^8.0.13",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
